# HZH Proposal Tool environment variables
# Copy this file to .env for local use only. Do not commit real secrets.

# Optional: move mutable data to a persistent disk in production.
# If unset, the app stores data inside the project directory.
# Example for Render/Railway persistent disk:
# HZH_STORAGE_DIR=/var/data/hzh-proposal-tool

# Optional overrides. Usually HZH_STORAGE_DIR is enough.
# HZH_DATA_DIR=/var/data/hzh-proposal-tool/data
# HZH_OUTPUTS_DIR=/var/data/hzh-proposal-tool/outputs
# HZH_POI_IMAGE_DIR=/var/data/hzh-proposal-tool/assets/poi_images

# Optional: enable DeepSeek-powered conversational generation.
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat
